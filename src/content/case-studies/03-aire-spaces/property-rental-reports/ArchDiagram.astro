---
const NODES = [
  { id: "hostaway", label: "Hostaway API", x: 60, y: 40, accent: false },
  { id: "csv", label: "CSV Upload", x: 60, y: 120, accent: false },
  { id: "ingest", label: "Ingest Layer", x: 220, y: 80, accent: true },
  { id: "supabase", label: "Supabase DB", x: 380, y: 80, accent: false },
  { id: "engine", label: "Report Engine", x: 540, y: 80, accent: true },
  { id: "pdf", label: "PDF Export", x: 700, y: 40, accent: false },
  { id: "portal", label: "Client Portal", x: 700, y: 120, accent: false },
];

const EDGES = [
  { from: { x: 140, y: 52 }, to: { x: 220, y: 92 } },
  { from: { x: 140, y: 128 }, to: { x: 220, y: 92 } },
  { from: { x: 300, y: 92 }, to: { x: 380, y: 92 } },
  { from: { x: 460, y: 92 }, to: { x: 540, y: 92 } },
  { from: { x: 620, y: 80 }, to: { x: 700, y: 52 } },
  { from: { x: 620, y: 92 }, to: { x: 700, y: 128 } },
];

const arrowPoints = (edge: typeof EDGES[number]) => {
  const dx = edge.to.x - edge.from.x;
  const dy = edge.to.y - edge.from.y;
  const len = Math.sqrt(dx * dx + dy * dy);
  const ux = dx / len;
  const uy = dy / len;
  const tx = edge.to.x - ux * 4;
  const ty = edge.to.y - uy * 4;
  return `${tx},${ty} ${tx - ux * 8 + uy * 4},${ty - uy * 8 - ux * 4} ${tx - ux * 8 - uy * 4},${ty - uy * 8 + ux * 4}`;
};
---

<figure class="border border-white/10 bg-white/[0.03] p-6 md:p-10 not-prose">
  <span class="text-[10px] uppercase tracking-widest text-[#FAFAFA]/40 block mb-6">
    System Architecture — Stage 1
  </span>
  <div class="w-full overflow-x-auto">
    <svg viewBox="0 0 800 180" class="w-full max-w-3xl mx-auto" aria-label="Architecture diagram: Hostaway and CSV sources feed an ingest layer into Supabase and the report engine, which outputs PDF exports and the client portal">
      {EDGES.map((edge) => (
        <line
          x1={edge.from.x}
          y1={edge.from.y}
          x2={edge.to.x}
          y2={edge.to.y}
          stroke="#2a2a2a"
          stroke-width="1.5"
          stroke-dasharray="4 3"
        ></line>
      ))}
      {EDGES.map((edge) => (
        <polygon points={arrowPoints(edge)} fill="#7EC7FF" opacity="0.7"></polygon>
      ))}
      {NODES.map((node) => (
        <g>
          <rect
            x={node.x}
            y={node.y - 14}
            width="80"
            height="28"
            fill={node.accent ? "#111111" : "#0d0d0d"}
            stroke={node.accent ? "#7EC7FF" : "#2a2a2a"}
            stroke-width={node.accent ? "1.5" : "1"}
          ></rect>
          <text
            x={node.x + 40}
            y={node.y + 5}
            text-anchor="middle"
            font-size="9"
            font-family="JetBrains Mono, monospace"
            fill={node.accent ? "#7EC7FF" : "#a0a0a0"}
            letter-spacing="0.5"
          >
            {node.label}
          </text>
        </g>
      ))}
      <text x="60" y="172" font-size="8" font-family="JetBrains Mono, monospace" fill="#5a5a5a" letter-spacing="1">SOURCES</text>
      <text x="200" y="172" font-size="8" font-family="JetBrains Mono, monospace" fill="#5a5a5a" letter-spacing="1">CORE</text>
      <text x="680" y="172" font-size="8" font-family="JetBrains Mono, monospace" fill="#5a5a5a" letter-spacing="1">DELIVERY</text>
      <line x1="60" y1="160" x2="140" y2="160" stroke="#2a2a2a" stroke-width="1"></line>
      <line x1="200" y1="160" x2="640" y2="160" stroke="#2a2a2a" stroke-width="1"></line>
      <line x1="680" y1="160" x2="780" y2="160" stroke="#2a2a2a" stroke-width="1"></line>
    </svg>
  </div>
  <div class="flex flex-wrap items-center gap-6 mt-6 pt-4 border-t border-white/10">
    <div class="flex items-center gap-2">
      <div class="w-6 h-px border-t border-dashed border-[#2a2a2a]"></div>
      <span class="text-[10px] text-[#FAFAFA]/40">Data flow</span>
    </div>
    <div class="flex items-center gap-2">
      <div class="w-3 h-3 border" style="border-color: #7EC7FF;"></div>
      <span class="text-[10px] text-[#FAFAFA]/40">Application layer</span>
    </div>
    <div class="flex items-center gap-2">
      <div class="w-3 h-3 border border-white/10"></div>
      <span class="text-[10px] text-[#FAFAFA]/40">External / storage</span>
    </div>
  </div>
</figure>
