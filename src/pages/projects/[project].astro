---
import { type CollectionEntry, getCollection, getEntries } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import ContactSection from "@components/ContactSection.astro";
import CaseStudyWindow from "@components/case-study/CaseStudyWindow.astro";
import WindowManagerScript from "@components/case-study/WindowManagerScript.astro";
import BlogCard from "@components/BlogCard.astro";
import { Terminal } from "@lucide/astro";

export async function getStaticPaths() {
  const projects = (await getCollection("projects"))
    .filter((p) => !p.data.draft);
  return projects.map((project) => ({
    params: { project: project.slug.replace(/\/index$/, "").split("/")[0] },
    props: { project },
  }));
}

type Props = { project: CollectionEntry<"projects"> };

const { project } = Astro.props;
const { Content } = await project.render();
const projectSlug = project.slug.replace(/\/index$/, "").split("/")[0];

const allCaseStudies = await getCollection("case-studies");
const caseStudies = allCaseStudies.filter((cs) => {
  if (cs.data.draft) return false;
  // Slugs are e.g. "03-aire-spaces/property-rental-reports"
  return cs.slug.startsWith(`${projectSlug}/`);
});

// Order: manual via project.caseStudyOrder, else by date descending
const order = project.data.caseStudyOrder ?? [];
const studySlug = (cs: CollectionEntry<"case-studies">) =>
  cs.slug.split("/").slice(1).join("/");

const sortedStudies = [...caseStudies].sort((a, b) => {
  const aSlug = studySlug(a);
  const bSlug = studySlug(b);
  const ai = order.indexOf(aSlug);
  const bi = order.indexOf(bSlug);
  if (ai !== -1 && bi !== -1) return ai - bi;
  if (ai !== -1) return -1;
  if (bi !== -1) return 1;
  return b.data.date.valueOf() - a.data.date.valueOf();
});

// Resolve services references for the meta block
const serviceEntries = project.data.services && project.data.services.length > 0
  ? await getEntries(project.data.services)
  : [];

const client = project.data.client ?? project.data.title;

const META_ROWS = [
  { label: "Client", value: client },
  project.data.industry && { label: "Industry", value: project.data.industry },
  project.data.location && { label: "Location", value: project.data.location },
  project.data.engagementType && {
    label: "Engagement type",
    value: project.data.engagementType === "ongoing" ? "Ongoing" : "One-off",
  },
  project.data.firstEngagement && {
    label: "First engagement",
    value: String(project.data.firstEngagement),
  },
  project.data.website && { label: "Website", value: project.data.website, href: project.data.website },
  serviceEntries.length > 0 && {
    label: serviceEntries.length === 1 ? "Service" : "Services",
    value: serviceEntries.map((s: any) => s.data.title).join(", "),
  },
].filter(Boolean) as { label: string; value: string; href?: string }[];

const defaultCta = (cs: CollectionEntry<"case-studies">) => {
  if (cs.data.ctaLabel) return cs.data.ctaLabel.replace(/\s*→\s*$/, "");
  if (cs.data.type === "experiment") return "Read experiment notes";
  return "Read case study";
};
---

<PageLayout
  title={`${client} — Project`}
  description={project.data.summary ?? project.data.description}
  breadcrumb={[
    { label: "Projects", href: "/projects" },
    { label: client },
  ]}
>
  <Container>
    <div class="page-fade-in space-y-10 max-w-screen-xl mx-auto">
      <!-- Project Hero -->
      <section class="space-y-8">
        <div class="space-y-2">
          <h1 class="text-6xl font-bold tracking-tight text-[#FAFAFA]">
            {client}
          </h1>
          {project.data.tagline && (
            <p class="text-lg text-body">{project.data.tagline}</p>
          )}
        </div>

        {project.data.tags && project.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-2">
            {project.data.tags.map((tag: string) => (
              <span class="px-3 py-1 text-[10px] uppercase tracking-widest border border-white/10 text-[#FAFAFA]/60">
                {tag}
              </span>
            ))}
          </div>
        )}

        {project.data.tldr && (
          <p class="max-w-3xl text-body leading-relaxed text-base">
            {project.data.tldr}
          </p>
        )}
      </section>

      {sortedStudies.length > 0 && (
        <section>
          <div class="flex items-center justify-between mb-6">
            <span class="text-[10px] uppercase tracking-[0.2em] text-[#FAFAFA]/40">Work</span>
            <span class="hidden md:flex items-center gap-2 text-[10px] text-[#FAFAFA]/40 font-mono uppercase tracking-widest">
              <Terminal size={10} />
              <span>Click to open · drag to rearrange</span>
            </span>
          </div>
          <ul class="list-none p-0">
            {sortedStudies.map((cs) => {
              const slug = studySlug(cs);
              const accent = cs.data.type === "experiment" ? "#F4915C" : "#7EC7FF";
              const statusLabel = cs.data.status ?? (cs.data.type === "experiment" ? "Experiment" : "Project");
              const canonical = `/projects/${projectSlug}/${slug}`;
              const interactive = cs.data.writeUp !== false;
              return (
                <li
                  class={`group relative flex items-start w-full border-t border-white/10 transition-colors ${interactive ? "hover:bg-white/5" : ""}`}
                >
                  <!-- Pulsing status indicator -->
                  <div class="absolute left-0 top-0 bottom-0 w-12 flex justify-center pointer-events-none" aria-hidden="true">
                    <div class="mt-10 relative w-3 h-3">
                      <span
                        class="absolute inset-0 rounded-full animate-ping opacity-60"
                        style={`background: ${accent};`}
                      ></span>
                      <span
                        class="relative block w-3 h-3 rounded-full"
                        style={`background: ${accent};`}
                      ></span>
                    </div>
                  </div>

                  {cs.data.writeUp !== false ? (
                    <a
                      href={canonical}
                      data-case-study-card={slug}
                      class="flex flex-col md:flex-row items-start w-full px-12 py-8 gap-6 no-underline text-inherit"
                      aria-label={`${cs.data.title} — ${defaultCta(cs).replace(/\s*→\s*$/, "")}`}
                    >
                      <!-- Title + description -->
                      <div class="flex-grow space-y-3 min-w-0">
                        <div class="flex flex-wrap items-center gap-3">
                          <h3
                            class="text-lg font-bold text-[#FAFAFA]"
                            style={`text-decoration-color: ${accent};`}
                          >
                            {cs.data.title}
                          </h3>
                          <span
                            class="px-2 py-0.5 text-[10px] uppercase tracking-widest border"
                            style={`border-color: ${accent}; color: ${accent};`}
                          >
                            {statusLabel}
                          </span>
                        </div>
                        <p class="text-sm leading-relaxed text-body max-w-2xl">
                          {cs.data.summary}
                        </p>
                      </div>

                      <!-- CTA cue (decorative — the whole card is the link) -->
                      <div class="shrink-0 pt-1 md:text-right" aria-hidden="true">
                        <span
                          class="text-xs font-mono inline-flex items-center gap-1.5"
                          style={`color: ${accent};`}
                        >
                          <Terminal
                            size={14}
                            class="opacity-70 group-hover:opacity-100 transition-opacity"
                          />
                          <span class="group-hover:underline underline-offset-2">
                            {defaultCta(cs)}
                          </span>
                        </span>
                      </div>
                    </a>
                  ) : (
                    <div class="flex flex-col md:flex-row items-start w-full px-12 py-8 gap-6">
                      <!-- Title + description -->
                      <div class="flex-grow space-y-3 min-w-0">
                        <div class="flex flex-wrap items-center gap-3">
                          <h3 class="text-lg font-bold text-[#FAFAFA]">{cs.data.title}</h3>
                          <span
                            class="px-2 py-0.5 text-[10px] uppercase tracking-widest border"
                            style={`border-color: ${accent}; color: ${accent};`}
                          >
                            {statusLabel}
                          </span>
                        </div>
                        <p class="text-sm leading-relaxed text-body max-w-2xl">
                          {cs.data.summary}
                        </p>
                      </div>

                      <!-- Non-clickable status note -->
                      <div class="shrink-0 pt-1 md:text-right">
                        <span class="text-xs text-[#FAFAFA]/40 italic">
                          {cs.data.ctaLabel ?? "In progress"}
                        </span>
                      </div>
                    </div>
                  )}
                </li>
              );
            })}
          </ul>
        </section>
      )}

      {/* About block + meta */}
      {(project.body.trim().length > 0 || META_ROWS.length > 0) && (
        <section class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-16 py-8 border-t border-white/10">
          <div class="space-y-6">
            <h2 class="text-[10px] uppercase tracking-[0.2em] text-[#FAFAFA]/40">
              About this project
            </h2>
            <article class="prose prose-invert max-w-none text-body">
              <Content />
            </article>
          </div>

          {META_ROWS.length > 0 && (
            <div class="border border-white/10 divide-y divide-white/10 self-start">
              {META_ROWS.map((row) => (
                <div class="flex justify-between items-center px-6 py-4 gap-4">
                  <span class="text-[11px] uppercase tracking-widest text-[#FAFAFA]/40 shrink-0">
                    {row.label}
                  </span>
                  {row.href ? (
                    <a
                      href={row.href}
                      target="_blank"
                      rel="noreferrer"
                      class="text-sm text-[#7EC7FF] hover:text-[#7EC7FF]/80 truncate"
                    >
                      {row.value.replace(/^https?:\/\//, "")}
                    </a>
                  ) : (
                    <span class="text-sm text-body text-right">{row.value}</span>
                  )}
                </div>
              ))}
            </div>
          )}
        </section>
      )}

      <ContactSection />
    </div>
  </Container>

  <!-- Hidden case-study windows (rendered server-side, opened by JS) -->
  {sortedStudies
    .filter((cs) => cs.data.writeUp !== false)
    .map((cs) => {
      const slug = studySlug(cs);
      return (
        <CaseStudyWindow
          entry={cs}
          slug={cs.slug}
          canonicalHref={`/projects/${projectSlug}/${slug}`}
        />
      );
    })}

  <WindowManagerScript />
</PageLayout>
