---
import { Layers, Database, Cpu, Lightbulb } from "@lucide/astro";

type Props = {
  title: string;
  icon?: "layers" | "database" | "cpu" | "lightbulb";
  accent?: "teal" | "amber";
  class?: string;
};

const { title, icon, accent = "teal", class: className = "" } = Astro.props;

const accentColor = accent === "amber" ? "#F4915C" : "#7EC7FF";
const Icon = icon === "database" ? Database : icon === "cpu" ? Cpu : icon === "lightbulb" ? Lightbulb : icon === "layers" ? Layers : null;
---

<div class={`border border-white/10 p-8 bg-white/[0.03] ${className}`}>
  <h4
    class="text-xs uppercase tracking-[0.2em] font-bold mb-6 flex items-center gap-3 text-[#FAFAFA]"
  >
    {Icon && <Icon size={14} color={accentColor} />}
    <span>{title}</span>
  </h4>
  <div class="text-sm text-body leading-relaxed space-y-4">
    <slot />
  </div>
</div>
