---
// Vertical list of outcomes, each row tagged with a short id in the left
// column (e.g. `01`, `02` or `A`, `B`). Wraps the whole thing in the same
// two-column sticky layout Stage uses — the "Outcomes" label sticks while
// the list scrolls past, and `heading` (if provided) sits at the top of
// the right column.
type Props = {
  outcomes: { title: string; description: string }[];
  heading?: string;
  /** ID style for the left column of each outcome row. */
  numbering?: "numeric" | "alpha";
  class?: string;
};

const {
  outcomes,
  heading,
  numbering = "numeric",
  class: className = "",
} = Astro.props;

const labelFor = (i: number) =>
  numbering === "alpha"
    ? String.fromCharCode(65 + i) // A, B, C…
    : String(i + 1).padStart(2, "0"); // 01, 02, 03…
---

{outcomes.length > 0 && (
  <section
    data-outcomes
    class={`not-prose grid grid-cols-1 md:grid-cols-[1fr_5fr] gap-3 md:gap-6 border-t border-base-300 pt-6 ${className}`}
  >
    <div>
      <div class="outcomes-label-sticky md:sticky">
        <span class="text-xs uppercase tracking-widest text-base-content/80 block pt-5">
          Outcomes
        </span>
      </div>
    </div>

    <div class="space-y-6">
      {heading && (
        <h2 class="!mt-0 text-2xl md:text-3xl font-bold leading-tight text-base-content">
          {heading}
        </h2>
      )}
      <ul class="list-none p-0 m-0 divide-y divide-base-300 border-b border-base-300">
        {outcomes.map((outcome, idx) => (
          <li class="grid grid-cols-[3rem_1fr] gap-6 py-4">
            <span class="font-mono text-xs uppercase tracking-widest text-base-content/60 pt-0.5">
              {labelFor(idx)}
            </span>
            <div>
              <h4 class="text-base-content text-sm font-bold mb-2">
                {outcome.title}
              </h4>
              <p class="text-body text-sm leading-relaxed">
                {outcome.description}
              </p>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>
)}

<style is:global>
  /* Same context-aware sticky pattern as Stage: page version clears the
     fixed site nav (5rem); window version sits just under the title bar
     (1rem). Self-contained so OutcomeGrid doesn't depend on Stage being
     rendered on the same page. */
  [data-outcomes] .outcomes-label-sticky {
    top: 5rem;
  }
  [data-window-body] [data-outcomes] .outcomes-label-sticky {
    top: 1rem;
  }
</style>
