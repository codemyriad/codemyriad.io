---
type Props = {
  outcomes: { title: string; description: string }[];
  heading?: string;
  class?: string;
};

const { outcomes, heading, class: className = "" } = Astro.props;
---

{outcomes.length > 0 && (
  <section class={`space-y-10 border-t border-white/10 pt-12 ${className}`}>
    <div class="space-y-6">
      <span class="text-[10px] uppercase tracking-widest text-[#FAFAFA]/40 block">Outcomes</span>
      {heading && (
        <h2 class="text-2xl md:text-3xl font-bold leading-tight text-[#FAFAFA]">{heading}</h2>
      )}
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-white/10 border border-white/10">
      {outcomes.map((outcome) => (
        <div class="bg-[#0A0A0A] p-6 h-full">
          <h4 class="text-[#FAFAFA] text-sm font-bold mb-3">{outcome.title}</h4>
          <p class="text-body text-xs leading-relaxed">{outcome.description}</p>
        </div>
      ))}
    </div>
  </section>
)}
