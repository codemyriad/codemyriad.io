---
// Generic draggable terminal-window chrome. Renders the titlebar, CRT
// effects, body, and status bar — everything that makes a "terminal app
// window" on this site. Whatever the caller passes via the slot becomes the
// window body content.
//
// Used directly by callers (e.g. `[project].astro` for case-study windows,
// `[project].astro` again for the /lab components-reference window). The
// WindowManagerScript watches for `[data-terminal-window]` to wire up drag,
// open/close, and z-ordering.
import { X, ArrowUpRight, Terminal, Minus } from "@lucide/astro";
import KbdChip from "@components/KbdChip.astro";

interface Props {
  /** Stable id used by the window manager (hash, z-order, etc.). */
  slug: string;
  /** Accent color for borders, title, and chrome buttons. */
  accent: string;
  /** Dim variant of accent for status-bar text. */
  accentDim?: string;
  /** Title-bar filename (the small mono label, e.g. `intro.log`). */
  filename: string;
  /** Optional popout link — if present, renders the popout chrome button. */
  popoutHref?: string;
  /** Optional terminal prompt line shown at the top of the body. */
  prompt?: string;
  /** Optional title rendered as a `// title` separator under the prompt. */
  title?: string;
  /** Default window dimensions; clamped to viewport in CSS. */
  width?: number;
  height?: number;
  /** Right-side status-bar label (e.g. "SHIPPED", "EXPERIMENT"). */
  statusLabel?: string;
  /** Left-side status-bar label (defaults to "STATUS: READ-ONLY"). */
  statusLeft?: string;
  /** Optional `data-window-type` for downstream styling/queries. */
  windowType?: string;
}

const {
  slug,
  accent,
  accentDim = "#2a4a6a",
  filename,
  popoutHref,
  prompt,
  title,
  width = 720,
  height = 480,
  statusLabel,
  statusLeft = "STATUS: READ-ONLY",
  windowType,
} = Astro.props;
---

<div
  data-terminal-window
  data-window-slug={slug}
  data-window-type={windowType}
  hidden
  class="terminal-window fixed flex flex-col"
  style={`
    width: min(${width}px, calc(100vw - 32px));
    height: min(${height}px, calc(100vh - 80px));
    box-shadow:
      0 0 0 2px #1a1a1a,
      0 0 0 4px ${accent},
      0 0 0 6px #0a0a0a,
      0 0 0 8px #1a1a1a,
      4px 4px 0 8px rgba(0,0,0,0.8),
      8px 8px 0 8px rgba(0,0,0,0.4);
  `}
  role="dialog"
  aria-labelledby={`window-title-${slug}`}
  aria-hidden="true"
>
  <!-- CRT vignette -->
  <div aria-hidden="true" class="crt-glow"></div>
  <!-- CRT scan-lines -->
  <div aria-hidden="true" class="crt-scanlines"></div>

  <!-- Title bar -->
  <header
    data-window-titlebar
    class="terminal-titlebar flex items-center justify-between gap-2 px-1.5 py-1.5 cursor-grab select-none"
    style={`background: #0a0a0a; border-bottom: 2px solid ${accent};`}
  >
    <div class="flex items-center gap-2 min-w-0">
      <Terminal size={14} color={accent} />
      <span
        id={`window-title-${slug}`}
        class="font-mono text-xs uppercase tracking-[0.12em] truncate"
        style={`color: ${accent};`}
      >
        {filename}
      </span>
    </div>
    <div class="flex items-center gap-1.5 shrink-0">
      {popoutHref && (
        <a
          href={popoutHref}
          data-window-popout
          class="terminal-chrome-btn"
          style={`border-color: ${accent};`}
          aria-label="Open in its own page"
          title="Open in own page"
        >
          <ArrowUpRight size={12} color={accent} />
        </a>
      )}
      <button
        type="button"
        class="terminal-chrome-btn"
        style="border-color: #3a3a3a; cursor: not-allowed;"
        aria-label="Minimize"
        disabled
      >
        <Minus size={12} color="#3a3a3a" />
      </button>
      <button
        type="button"
        data-window-close
        class="terminal-chrome-btn"
        style={`border-color: ${accent};`}
        aria-label="Close"
        aria-keyshortcuts="Escape"
      >
        <X size={12} color={accent} />
      </button>
    </div>
  </header>

  <!-- Body (scrollable). Padding-top lives on the inner wrapper, NOT the
       body itself, so that `position: sticky` children measure their `top`
       offset from the body's outer top edge (= just under the title bar)
       instead of from inside the padding. Visual breathing room stays the
       same; sticky math becomes intuitive. -->
  <div
    data-window-body
    class="terminal-body flex-1 overflow-y-auto px-5 pb-4"
  >
    <div class="pt-8">
      {prompt && (
        <div class="terminal-prompt mb-3 text-[10px] font-mono">
          <span class="terminal-prompt-host" style={`color: ${accent};`}>codemyriad@projects:~$ </span><span class="terminal-prompt-cmd">{prompt}</span>
        </div>
      )}

      {title && (
        <div class="mb-4 pb-3 border-b border-white/10">
          <span
            class="font-mono font-bold uppercase tracking-[0.05em] text-[13px]"
            style={`color: ${accent};`}
          >
            // {title}
          </span>
        </div>
      )}

      <div class="terminal-content">
        <slot />
      </div>

      <!-- End-of-content marker. Standard chrome for every window — signals
           you've reached the bottom and reminds how to close. -->
      <div
        class="not-prose mt-12 pt-6 border-white/10 flex justify-start items-start gap-2 font-mono text-[10px] uppercase tracking-widest text-[#FAFAFA]/45"
      >
        <KbdChip keys="Esc" text />
        <span>to close this window</span>
      </div>
    </div>
  </div>

</div>

<style>
  .terminal-window {
    transform-origin: top left;
    background: #0A0A0A;
  }

  /* Open animation — mirrors the framer-motion spring (stiffness 320, damping 26)
     from the reference: scale 0.88 → 1, y +20 → 0, opacity 0 → 1, gentle overshoot. */
  .terminal-window[data-window-opening="true"] {
    animation: window-open 320ms cubic-bezier(0.22, 1.3, 0.36, 1);
  }
  @keyframes window-open {
    from {
      opacity: 0;
      transform: scale(0.88) translateY(20px);
    }
    to {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
  }

  /* Close animation — same duration as open, with mirrored "anticipation" easing
     so it feels symmetrically snappy (instead of slow-starting). */
  .terminal-window[data-window-closing="true"] {
    animation: window-close 320ms cubic-bezier(0.36, 0, 0.78, -0.3) forwards;
    pointer-events: none;
  }
  @keyframes window-close {
    from {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
    to {
      opacity: 0;
      transform: scale(0.84) translateY(16px);
    }
  }

  /* CRT phosphor vignette (below content) — neutral dark tint */
  .crt-glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    background: radial-gradient(ellipse at 50% 40%, transparent 50%, rgba(0, 0, 0, 0.55) 100%);
  }

  /* CRT scanlines (above content for that retro vibe) */
  .crt-scanlines {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 50;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0, 0, 0, 0.1) 2px,
      rgba(0, 0, 0, 0.1) 4px
    );
  }

  /* Layer page content above vignette, below scanlines */
  .terminal-titlebar,
  .terminal-body,
  .terminal-statusbar {
    position: relative;
    z-index: 10;
  }

  /* Chrome buttons (titlebar) */
  .terminal-chrome-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 16px;
    height: 16px;
    background: #111111;
    border: 1px solid;
    cursor: pointer;
  }
  .terminal-chrome-btn:disabled {
    cursor: not-allowed;
  }

  /* Body palette — site colors with mono font */
  .terminal-body {
    background: #0A0A0A;
    color: #FAFAFA;
    font-family: "JetBrains Mono", "Courier New", Courier, monospace;
    line-height: 1.65;
  }

  .terminal-prompt-cmd {
    color: rgba(250, 250, 250, 0.85);
  }
</style>
