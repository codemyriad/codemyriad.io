---
// Quiet italic aside with a neutral white left border. Use sparingly — for
// a single sentence of meta-commentary inside a stage. No color variant
// (intentionally distinct from Quote, which carries the accent bar).
type Props = {
  class?: string;
};

const { class: className = "" } = Astro.props;
---

<div class={`not-prose p-4 bg-white/5 border-l-2 border-base-content/25 ${className}`}>
  <p class="text-sm italic text-base-content leading-relaxed max-w-2xl">
    <slot />
  </p>
</div>
