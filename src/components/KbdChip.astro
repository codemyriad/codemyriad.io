---
// Keyboard-shortcut indicator. Single source of truth for chip styling —
// every place that shows a typeable shortcut renders this. The global
// KeyboardShortcuts script picks up `data-shortcut` and clicks the nearest
// `<a>` / `<button>` ancestor when the user types the matching keys.
//
// Default mode: each character is its own square keycap (so 1-char shortcuts
// are naturally square and multi-char shortcuts read as "press these keys in
// sequence"). `text` mode: the whole label renders as a single wider cell —
// for named keys like "Esc" that aren't a sequence of typeable keystrokes.
// Hidden under `sm` because typing keys without a keyboard isn't useful.
interface Props {
  keys: string;
  class?: string;
  text?: boolean;
}

const { keys, class: className, text = false } = Astro.props;
const chars = keys.toUpperCase().split("");
---

<kbd
  data-shortcut={keys.toUpperCase()}
  class:list={[
    "hidden sm:inline-flex items-center gap-0.5 shrink-0",
    className,
  ]}
>
  {text ? (
    <span class="inline-flex items-center justify-center h-3.5 px-1 font-sans text-[10px] leading-[13px] border border-base-300 bg-white/10 text-base-content/70 transition-colors">{keys}</span>
  ) : (
    chars.map((ch) => (
      <span class="inline-flex items-center justify-center w-3.5 h-3.5 font-sans text-[10px] leading-[13px] uppercase border border-base-300 bg-white/10 text-base-content/70 transition-colors">{ch}</span>
    ))
  )}
</kbd>
