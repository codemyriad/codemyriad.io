---
import { ArrowUp } from "@lucide/astro";
---

<button
  id="back-to-top"
  data-visible="false"
  class="btn btn-outline btn-xs h-7 min-h-7 hidden sm:inline-flex fixed bottom-4 right-[50px] z-40 gap-1.5 backdrop-blur-sm bg-black/40 opacity-0 pointer-events-none data-[visible=true]:opacity-100 data-[visible=true]:pointer-events-auto transition-all duration-300 ease-in-out"
  aria-label="Back to top"
>
  <ArrowUp size={12} />
  <span>Back to top</span>
</button>

<script>
  // Fade in the back-to-top button only when the user has scrolled to the
  // page footer (= effectively the bottom of the page). The button itself is
  // fixed-positioned and inline with the keyboard-shortcut guide icon, so we
  // observe the footer as the "at-bottom" sentinel.
  const init = () => {
    const btn = document.getElementById("back-to-top");
    const sentinel = document.querySelector("footer");
    if (!btn || !sentinel) return;
    if (btn.dataset.btInit === "true") return;
    btn.dataset.btInit = "true";
    if (typeof IntersectionObserver === "undefined") {
      btn.setAttribute("data-visible", "true");
      return;
    }
    const obs = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          btn.setAttribute(
            "data-visible",
            entry.isIntersecting ? "true" : "false"
          );
        }
      },
      { threshold: 0.1 }
    );
    obs.observe(sentinel);
  };
  init();
  document.addEventListener("astro:page-load", init);
</script>
