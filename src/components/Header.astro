---
import Container from "@components/Container.astro";
import Link from "@components/Link.astro";
import { SITE } from "@consts";

// Always prefix with `/` so anchors work from any page and the header can be
// safely persisted across view-transition navigations.
const navHref = (hash: string) => `/${hash}`;
---

<header transition:persist transition:name="site-nav">
  <Container>
    <div class="flex flex-wrap items-center gap-y-3 justify-between">
      <Link href="/" underline={false}>
        <img
          src="/logo.svg"
          alt={`${SITE.NAME} logo`}
          class="h-7 w-auto"
          loading="eager"
        />
      </Link>
      <nav
        class="flex flex-wrap items-center gap-5 text-xs sm:text-sm text-[#FAFAFA]/60"
      >
        <Link href={navHref("#services")} underline={false}>Services</Link>
        <Link href={navHref("#projects")} underline={false}>Projects</Link>
        <Link href={navHref("#blog")} underline={false}>Blog</Link>
        <Link href={navHref("#contact")} underline={false}>Contact</Link>
      </nav>
    </div>
  </Container>
</header>
